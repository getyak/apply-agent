# Purpose: Cross-editor whitespace consistency. Stops "huge diff because spaces" PRs.
# Trigger: Automatic in VSCode/JetBrains/Neovim with editorconfig plugin.

root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,jsonc}]
indent_size = 2

[*.{yml,yaml,toml}]
indent_size = 2

[*.sql]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
