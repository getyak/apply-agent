{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY; next dev --webpack",
    "dev:turbo": "unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "bunx tsc --noEmit",
    "smoke:hydration": "node ../scripts/web-hydration-smoke.mjs",
    "smoke:route": "node ../scripts/web-route-smoke.mjs",
    "smoke:seo": "node ../scripts/seo-validate.mjs",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.57",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-virtual": "^3.10.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
