# ============================================
# Relay - Environment Variables
# Copy to .env and fill in real values
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=relay
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password
POSTGRES_DB=relay
POSTGRES_PORT=5433
DATABASE_URL=postgresql://relay:CHANGE_ME_use_a_strong_password@localhost:5433/relay

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_PORT=6380
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6380/0

# --- DuckDB (embedded, path only) ---
DUCKDB_PATH=./data/analytics.duckdb

# --- Supabase Storage (S3-compatible, for user files) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=relay_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=relay-user-files
S3_REGION=us-east-1

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model tiers (Chinese models, best cost-performance)
LLM_MODEL_HEAVY=deepseek/deepseek-v4-pro
LLM_MODEL_GENERAL=z-ai/glm-4.7
LLM_MODEL_FAST=deepseek/deepseek-v4-flash

# --- Application ---
NODE_ENV=development
API_PORT=3001
AGENT_SERVICE_PORT=8000
JWT_SECRET=CHANGE_ME_jwt_secret
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
