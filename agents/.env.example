# ============================================
# Relay agents layer — environment variables
# Copy to agents/.env (or set in the shared root .env) and fill real values.
# The root .env.example is the canonical superset; this file lists the subset
# the Python agents read, plus PR4's browser-extension token.
# ============================================

# --- PostgreSQL (LangGraph PostgresSaver + node DB I/O) ---
RELAY_PG_DSN=postgresql://relay:CHANGE_ME@localhost:5433/relay

# --- Redis (cache + event bus, port 6380) ---
RELAY_REDIS_URL=redis://localhost:6380/0

# --- LLM (OpenRouter, NOT the Claude API) ---
OPENROUTER_API_KEY=sk-or-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Object storage (MinIO/S3) — large browser screenshots offload here ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=relay_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=relay-user-files
S3_REGION=us-east-1

# --- Playwright MCP Chrome Extension (PR4: client-side browser tools) ---
# Install the extension from the Chrome Web Store
# (id mmlmfjhmonkocbjadbfplnigmagldckm), open its popup, and paste the token it
# shows here. When this is EMPTY, browser tools degrade gracefully and return
# BROWSER_EXT_NOT_INSTALLED instead of failing. PLAYWRIGHT_MCP_EXTENSION_URL only
# needs overriding if the extension binds a non-default loopback port.
PLAYWRIGHT_MCP_EXTENSION_TOKEN=
# PLAYWRIGHT_MCP_EXTENSION_URL=http://127.0.0.1:8931/mcp
